source "https://rubygems.org"

# Matches the Jekyll/plugin versions GitHub Pages uses in production.
# Run `bundle install` then `bundle exec jekyll serve` to preview locally.
gem "github-pages", group: :jekyll_plugins

# Ruby 3.4+ dropped these from the default gems; github-pages' old Jekyll
# still expects them to just be there.
gem "csv"
gem "base64"
gem "bigdecimal"
